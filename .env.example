VITE_API_BASE_URL=http://127.0.0.1:5050/api

PORT=5050
FRONTEND_URL=http://127.0.0.1:5173
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
SUPABASE_ANON_KEY=your_publishable_or_anon_key_for_dev_fallback
JWT_SECRET=replace_this_with_a_long_secret

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
AI_PROVIDER_ORDER=groq,cloudflare,openrouter,gemini
AI_REQUEST_TIMEOUT_MS=12000
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openrouter/free
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_MODEL=@cf/meta/llama-3.1-8b-instruct

ADMIN_BOOTSTRAP_EMAILS=admin@spa.local
ALLOW_RESET_TOKEN_IN_RESPONSE=true
RATE_LIMIT_AUTH_CAPACITY=8
RATE_LIMIT_AUTH_REFILL_PER_SEC=0.2
RATE_LIMIT_AUTH_BLOCK_MS=300000
RATE_LIMIT_CONTENT_CAPACITY=20
RATE_LIMIT_CONTENT_REFILL_PER_SEC=0.5
RATE_LIMIT_CONTENT_BLOCK_MS=60000
RATE_LIMIT_AUTOPOST_CAPACITY=8
RATE_LIMIT_AUTOPOST_REFILL_PER_SEC=0.08
RATE_LIMIT_AUTOPOST_BLOCK_MS=120000

VITE_VIETQR_BANK_ID=mbbank
VITE_VIETQR_BANK_LABEL=MB Bank
VITE_VIETQR_ACCOUNT_NO=0339428018
VITE_VIETQR_ACCOUNT_NAME=NGUYEN GIA BAO
VITE_PAYMENT_QR_IMAGE_URL=

# ===== ZERNIO SOCIAL AUTO-POST (SERVER SIDE) =====
# Base URL can be changed if your Zernio account uses another host/version.
ZERNIO_API_BASE_URL=https://zernio.com/api/v1
ZERNIO_API_KEY=

# Connected account IDs from Zernio dashboard/list-accounts endpoint.
ZERNIO_ACCOUNT_ID_FACEBOOK=
ZERNIO_ACCOUNT_ID_INSTAGRAM=
# Optional: leave empty if you don't use TikTok
ZERNIO_ACCOUNT_ID_TIKTOK=

# Active platforms for auto-post flow
ZERNIO_ENABLED_PLATFORMS=facebook,instagram

# Post behavior
# true  = if 1 platform fails, still publish on remaining platforms
# false = fail the whole request if any platform fails
ZERNIO_ALLOW_PARTIAL_SUCCESS=true
ZERNIO_PUBLISH_TIMEOUT_MS=20000
ZERNIO_RETRY_ATTEMPTS=2
ZERNIO_ACCOUNT_CACHE_TTL_MS=300000
ZERNIO_SCHEDULE_JITTER_SECONDS=180
ZERNIO_DEFAULT_TIMEZONE=Asia/Bangkok

# Media guardrails (for upload validation in backend)
ZERNIO_MAX_IMAGE_MB=10
ZERNIO_MAX_VIDEO_MB=300

# ===== WEBHOOK (STATUS CALLBACK FROM ZERNIO) =====
# Zernio will call: https://<your-domain><ZERNIO_WEBHOOK_PATH>
ZERNIO_WEBHOOK_PATH=/api/integrations/zernio/webhook
# Secret used to verify webhook signature (set same value in Zernio webhook config)
ZERNIO_WEBHOOK_SECRET=
